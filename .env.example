PROJECT_ID=
CMS_API_KEY=
CMS_BASE_URL=https://api.kantan-cms.com

KANTAN_STORAGE_PATH=./tmp

KANTAN_REQUIRED_COLLECTION_IDS=

# Astro only exposes a variable to browser-side code when it is prefixed
# PUBLIC_. Anything referenced as import.meta.env.PUBLIC_* must be declared
# here, or it resolves to undefined in the built site.
PUBLIC_CMS_BASE_URL=https://api.kantan-cms.com
PUBLIC_POST_COLLECTION_ID=
